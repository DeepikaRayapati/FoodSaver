{
  "name": "foodsaver-monorepo",
  "version": "1.0.0",
  "description": "FoodSaver - Food Waste Reduction Platform",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "client-install": "cd frontend && npm install",
    "server-install": "cd backend && npm install",
    "start": "cd backend && npm start",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run install-all && cd frontend && npm run build",
    "heroku-postbuild": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
